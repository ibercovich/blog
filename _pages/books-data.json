---
layout: null
permalink: /books/data.json
---
{% assign books = site.books | sort_natural: "title" %}
[
{% for book in books %}
  {
    "title": {{ book.title | jsonify }},
    "author": {{ book.author | jsonify }},
    "isbn": {{ book.isbn | jsonify }},
    "cover": {{ book.cover | jsonify }},
    "color": {{ book.color | jsonify }},
    "synopsis": {{ book.synopsis | jsonify }},
    "status": {{ book.status | jsonify }},
    "collections": {{ book.collections | jsonify }},
    "physical_copy": {{ book.physical_copy | jsonify }},
    "recommended": {{ book.recommended | jsonify }},
    "finished_on": {{ book.finished_on | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
